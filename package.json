{
  "name": "mdviewer",
  "version": "3.1.1",
  "description": "AI-first, local-first Markdown copilot with context-aware chat and Mermaid support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-icon": "node scripts/build-icon.js",
    "build": "node scripts/build.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "node scripts/publish-tag.js"
  },
  "author": "Alexander Lyakhov",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.5",
    "@electron/notarize": "^2.3.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "electron-store": "^10.0.0",
    "highlight.js": "^11.9.0",
    "katex": "^0.16.40",
    "marked": "^11.0.0",
    "marked-highlight": "^2.2.3",
    "marked-katex-extension": "^5.1.7",
    "mermaid": "^10.6.1",
    "pdf-parse": "^1.1.1"
  },
  "build": {
    "appId": "com.mdviewer.app",
    "productName": "MD Viewer",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Viewer"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "role": "Viewer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "afterSign": "scripts/notarize.js"
  }
}
